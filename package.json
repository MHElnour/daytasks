{
  "name": "daytasks",
  "version": "0.4.3",
  "description": "A lightweight, day-first task manager for your daily notes.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node build-css.mjs && node esbuild.config.mjs",
    "build": "tsc --noEmit && node build-css.mjs && node esbuild.config.mjs --production",
    "build:test": "npm run build && npm run install-plugin -- ./daytask-vault",
    "build-css": "node build-css.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run test",
    "lint:md": "markdownlint \"**/*.md\"",
    "lint:md:fix": "markdownlint --fix \"**/*.md\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "node scripts/release.mjs",
    "release:publish": "node scripts/release-publish.mjs",
    "install-plugin": "node scripts/install-to-vault.mjs"
  },
  "devDependencies": {
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.2",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.5.0",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "happy-dom": "^20.10.6",
    "obsidian": "^1.13.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "sortablejs": "^1.15.7"
  }
}
