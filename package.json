{
  "name": "daytasks",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node build-css.mjs && node esbuild.config.mjs",
    "build": "tsc --noEmit && node build-css.mjs && node esbuild.config.mjs --production",
    "build-css": "node build-css.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "install-plugin": "node scripts/install-to-vault.mjs"
  },
  "devDependencies": {
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.2",
    "happy-dom": "^20.10.6",
    "obsidian": "^1.13.1",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  }
}
