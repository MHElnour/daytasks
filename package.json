{
  "name": "daytasks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node build-css.mjs && node esbuild.config.mjs",
    "build": "tsc --noEmit && node build-css.mjs && node esbuild.config.mjs --production",
    "build:test": "npm run build && npm run install-plugin -- ./daytask-vault",
    "build-css": "node build-css.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run typecheck && npm run test",
    "release": "node scripts/release.mjs",
    "release:publish": "node scripts/release-publish.mjs",
    "install-plugin": "node scripts/install-to-vault.mjs"
  },
  "devDependencies": {
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.2",
    "@vitest/coverage-v8": "^2.1.9",
    "happy-dom": "^20.10.6",
    "obsidian": "^1.13.1",
    "typescript": "^5.0.0",
    "vitest": "^2.1.9"
  }
}
